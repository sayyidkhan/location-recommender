# WaveSpeed AI API key - get yours at https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=your_api_key_here

# API key to protect the /api/recommend endpoint (optional - if set, clients must send it)
# Send via header: Authorization: Bearer <key> or X-API-Key: <key>
RECOMMEND_API_KEY=your_recommend_api_key_here
